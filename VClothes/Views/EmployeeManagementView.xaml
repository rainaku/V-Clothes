<UserControl x:Class="VClothes.Views.EmployeeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- Left: List -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Danh sách nhân viên" Style="{StaticResource HeadlineStyle}"/>
                    <Button Content="+ Thêm nhân viên" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>

                <TextBox Grid.Row="1" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Margin="0,0,0,12"/>

                <DataGrid Grid.Row="2" 
                          ItemsSource="{Binding Employees}"
                          SelectedItem="{Binding SelectedEmployee}"
                          Style="{StaticResource MacDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource MacDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource MacDataGridCellStyle}"
                          RowStyle="{StaticResource MacDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NV" Binding="{Binding EmployeeCode}" Width="70"/>
                        <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Chức vụ" Binding="{Binding Position}" Width="100"/>
                        <DataGridTextColumn Header="Điện thoại" Binding="{Binding Phone}" Width="110"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFF0EB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="#EBFFF0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Nghỉ việc"/>
                                                    <Setter Property="Foreground" Value="#FF3B30"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Text" Value="Đang làm"/>
                                                            <Setter Property="Foreground" Value="#34C759"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Right: Edit Form -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Thông tin nhân viên" 
                               Style="{StaticResource HeadlineStyle}" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MÃ NHÂN VIÊN" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditEmployeeCode, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="HỌ TÊN" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditFullName, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GIỚI TÍNH" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox SelectedItem="{Binding EditGender}"
                                      Style="{StaticResource MacComboBoxStyle}">
                                <ComboBoxItem Content="Nam"/>
                                <ComboBoxItem Content="Nữ"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NGÀY SINH" Style="{StaticResource FormLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding EditDateOfBirth}"
                                        Style="{StaticResource MacDatePickerStyle}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="ĐIỆN THOẠI" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MacTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="EMAIL" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MacTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="ĐỊA CHỈ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MacTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="CHỨC VỤ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditPosition, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MacTextBoxStyle}"/>
                    </StackPanel>

                    <CheckBox Content="Đang làm việc" 
                              IsChecked="{Binding EditIsActive}"
                              FontFamily="{StaticResource SFProFont}" FontSize="13"
                              Margin="0,12,0,16"/>

                    <!-- Validation -->
                    <TextBlock Text="{Binding ValidationMessage}" 
                               FontFamily="{StaticResource SFProFont}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValidationMessage, Converter={StaticResource StringNotEmpty}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ValidationMessage}" Value="Lưu thành công!">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                        <Button Content="Xóa" Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding DeleteCommand}" Margin="0,0,8,0"/>
                        <Button Content="Lưu" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="👤" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Chọn hoặc thêm nhân viên" 
                           Style="{StaticResource SecondaryBodyStyle}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
