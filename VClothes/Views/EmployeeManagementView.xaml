<UserControl x:Class="VClothes.Views.EmployeeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters"
             xmlns:views="clr-namespace:VClothes.Views">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Danh sách nhân viên" Style="{StaticResource HeadlineStyle}"/>
                <Button Content="+ Thêm nhân viên" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding LenhThem}" HorizontalAlignment="Right"/>
            </Grid>

            <TextBox Grid.Row="1" Text="{Binding TimKiem, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,12"/>

            <!-- Skeleton Loading -->
            <views:SkeletonLoading Grid.Row="2"
                                   Visibility="{Binding DangTai, Converter={StaticResource BoolToVisibility}}"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding DangTai, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                <ItemsControl ItemsSource="{Binding DanhSachNhanVien}"
                              converters:StaggerAnimationBehavior.IsEnabled="True">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,4" CornerRadius="8" Background="White"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonDown="MucDuocChon_Click">
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding MaNhanVien}" FontFamily="{StaticResource SFProFont}" FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding HoTen}" FontWeight="Medium"
                                               FontFamily="{StaticResource SFProFont}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ChucVu}" FontFamily="{StaticResource SFProFont}" FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding DienThoai}" FontFamily="{StaticResource SFProFont}" FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="4" CornerRadius="10" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFF0EB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DangHoatDong}" Value="True">
                                                        <Setter Property="Background" Value="#EBFFF0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Medium" FontFamily="{StaticResource SFProFont}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Nghỉ"/>
                                                    <Setter Property="Foreground" Value="#FF3B30"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DangHoatDong}" Value="True">
                                                            <Setter Property="Text" Value="Đang làm"/>
                                                            <Setter Property="Foreground" Value="#34C759"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Slide-up Edit Panel -->
            <Border Grid.Row="2" VerticalAlignment="Bottom"
                    Visibility="{Binding DangSua, Converter={StaticResource BoolToVisibility}}"
                    Background="White" CornerRadius="12" Padding="20" Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
                <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DangSua}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Thông tin nhân viên" Style="{StaticResource HeadlineStyle}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="MÃ NV" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SuaMaNhanVien, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="HỌ TÊN" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SuaHoTen, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="CHỨC VỤ" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SuaChucVu, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="ĐIỆN THOẠI" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SuaDienThoai, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="EMAIL" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SuaEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="ĐỊA CHỈ" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SuaDiaChi, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="Đang làm việc" IsChecked="{Binding SuaDangHoatDong}"
                              FontFamily="{StaticResource SFProFont}" FontSize="13" Margin="0,10,0,0"/>

                    <TextBlock Text="{Binding ThongBaoXacThuc}" FontFamily="{StaticResource SFProFont}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ThongBaoXacThuc, Converter={StaticResource StringNotEmpty}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ThongBaoXacThuc}" Value="Lưu thành công!">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Hủy" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding LenhHuy}" Margin="0,0,8,0"/>
                        <Button Content="Xóa" Style="{StaticResource DangerButtonStyle}" Command="{Binding LenhXoa}" Margin="0,0,8,0"/>
                        <Button Content="Lưu" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding LenhLuu}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
