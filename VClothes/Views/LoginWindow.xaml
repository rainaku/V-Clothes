<Window x:Class="VClothes.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VClothes.ViewModels"
        xmlns:converters="clr-namespace:VClothes.Converters"
        Title="V-Clothes - Đăng nhập" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:DangNhapViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
    </Window.Resources>

    <Border CornerRadius="12" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Branding -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12">
                <Border.Background>
                    <ImageBrush ImageSource="/Styles/C6D811AD-D785-4611-91CE-3AA6E721CB89.webp" Stretch="UniformToFill"/>
                </Border.Background>

                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="V Clothes" 
                                   FontFamily="{StaticResource SFProFont}"
                                   FontSize="32" FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.6" Color="#000000"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Hệ thống quản lý cửa hàng áo thun" 
                                   FontFamily="{StaticResource SFProFont}"
                                   FontSize="14" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.6" Color="#000000"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Panel - Login Form -->
            <Grid Grid.Column="1" Margin="40,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Đăng nhập" 
                               Style="{StaticResource Title1Style}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Vui lòng đăng nhập để tiếp tục" 
                               Style="{StaticResource SecondaryBodyStyle}"
                               Margin="0,0,0,32"/>

                    <!-- Username -->
                    <TextBlock Text="TÊN ĐĂNG NHẬP" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource MacTextBoxStyle}"
                             Margin="0,0,0,16"/>

                    <!-- Password -->
                    <TextBlock Text="MẬT KHẨU" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource MacPasswordBoxStyle}"
                                 Margin="0,0,0,8"/>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ThongBaoLoi}" 
                               Foreground="{StaticResource AccentRedBrush}"
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="12"
                               Margin="0,4,0,16"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ThongBaoLoi, Converter={StaticResource StringNotEmpty}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Login Button -->
                    <Button Content="Đăng nhập" 
                            Command="{Binding LenhDangNhap}"
                            CommandParameter="{Binding ElementName=PasswordBox}"
                            Height="40" FontSize="14"
                            Margin="0,8,0,0"
                            Cursor="Hand"
                            FontFamily="{StaticResource SFProFont}"
                            FontWeight="Medium"
                            Foreground="White">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" 
                                        Background="#1A1A1A" 
                                        CornerRadius="8"
                                        Padding="16,8"
                                        SnapsToDevicePixels="True">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1" CenterX="160" CenterY="20"/>
                                    </Border.RenderTransform>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#333333"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#000000"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="btnScale" 
                                                                 Storyboard.TargetProperty="ScaleX" 
                                                                 To="1.02" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="btnScale" 
                                                                 Storyboard.TargetProperty="ScaleY" 
                                                                 To="1.02" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="btnScale" 
                                                                 Storyboard.TargetProperty="ScaleX" 
                                                                 To="1.0" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="btnScale" 
                                                                 Storyboard.TargetProperty="ScaleY" 
                                                                 To="1.0" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Loading -->
                    <TextBlock Text="Đang xử lý..." 
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="12"
                               Margin="0,12,0,0"
                               Visibility="{Binding DangTai, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Footer -->
                    <TextBlock Text="© 2025 V-Clothes. All rights reserved." 
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TertiaryTextBrush}"
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="11"
                               Margin="0,40,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Drag area -->
            <Border Grid.ColumnSpan="2" Height="40" VerticalAlignment="Top" 
                    Background="Transparent" MouseLeftButtonDown="VungKeo_MouseLeftButtonDown"/>

            <!-- Windows Window Controls (above drag area) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" 
                        HorizontalAlignment="Right" Margin="0,0,0,0" Panel.ZIndex="10">
                <!-- Minimize -->
                <Button Click="NutThuNho_Click" Cursor="Hand" Width="46" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent">
                                <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E5E5E5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Close -->
                <Button Click="NutDong_Click" Cursor="Hand" Width="46" Height="32">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,12,0,0">
                                <TextBlock x:Name="icon" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                    <Setter TargetName="icon" Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
