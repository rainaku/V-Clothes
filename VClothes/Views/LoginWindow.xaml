<Window x:Class="VClothes.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VClothes.ViewModels"
        xmlns:converters="clr-namespace:VClothes.Converters"
        Title="V-Clothes - Đăng nhập" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
    </Window.Resources>

    <Border CornerRadius="12" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Branding -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12" Background="#001F3F">

                <Grid>
                    <!-- Close Button -->
                    <Button HorizontalAlignment="Left" VerticalAlignment="Top" 
                            Margin="16,16,0,0" Width="12" Height="12"
                            Click="CloseButton_Click"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse x:Name="dot" Fill="#FF5F57" Width="12" Height="12"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="dot" Property="Fill" Value="#E0443E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="V-Clothes" 
                                   FontFamily="{StaticResource SFProFont}"
                                   FontSize="32" FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Hệ thống quản lý cửa hàng áo thun" 
                                   FontFamily="{StaticResource SFProFont}"
                                   FontSize="14" 
                                   Foreground="#FFFFFFCC" 
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Panel - Login Form -->
            <Grid Grid.Column="1" Margin="40,0">
                <!-- macOS Window Dots -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" 
                            HorizontalAlignment="Right" Margin="0,16,16,0">
                    <Button Click="MinimizeButton_Click" Cursor="Hand" Margin="4,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse x:Name="dot" Fill="#FFBD2E" Width="12" Height="12"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="dot" Property="Fill" Value="#E0A528"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Đăng nhập" 
                               Style="{StaticResource Title1Style}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Vui lòng đăng nhập để tiếp tục" 
                               Style="{StaticResource SecondaryBodyStyle}"
                               Margin="0,0,0,32"/>

                    <!-- Username -->
                    <TextBlock Text="TÊN ĐĂNG NHẬP" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource MacTextBoxStyle}"
                             Margin="0,0,0,16"/>

                    <!-- Password -->
                    <TextBlock Text="MẬT KHẨU" Style="{StaticResource FormLabelStyle}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource MacPasswordBoxStyle}"
                                 Margin="0,0,0,8"/>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="{StaticResource AccentRedBrush}"
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="12"
                               Margin="0,4,0,16"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Login Button -->
                    <Button Content="Đăng nhập" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=PasswordBox}"
                            Height="40" FontSize="14"
                            Margin="0,8,0,0"/>

                    <!-- Loading -->
                    <TextBlock Text="Đang xử lý..." 
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="12"
                               Margin="0,12,0,0"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Footer -->
                    <TextBlock Text="© 2025 V-Clothes. All rights reserved." 
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TertiaryTextBrush}"
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="11"
                               Margin="0,40,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Drag area -->
            <Border Grid.ColumnSpan="2" Height="40" VerticalAlignment="Top" 
                    Background="Transparent" MouseLeftButtonDown="DragArea_MouseLeftButtonDown"/>
        </Grid>
    </Border>
</Window>
