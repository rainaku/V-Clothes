<UserControl x:Class="VClothes.Views.RevenueStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters">

    <UserControl.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter Bar -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Từ ngày:" VerticalAlignment="Center" 
                           Style="{StaticResource SecondaryBodyStyle}" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}"
                            Style="{StaticResource MacDatePickerStyle}" Width="140"/>

                <TextBlock Grid.Column="2" Text="Đến ngày:" VerticalAlignment="Center" 
                           Style="{StaticResource SecondaryBodyStyle}" Margin="16,0,8,0"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding ToDate}"
                            Style="{StaticResource MacDatePickerStyle}" Width="140"/>

                <Button Grid.Column="5" Content="Xem thống kê" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding FilterCommand}"/>
            </Grid>
        </Border>

        <!-- Summary Cards -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Tổng doanh thu" Style="{StaticResource CaptionStyle}"/>
                    <TextBlock Text="{Binding TotalRevenue, Converter={StaticResource CurrencyConverter}}" 
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Số hóa đơn" Style="{StaticResource CaptionStyle}"/>
                    <TextBlock Text="{Binding TotalInvoices}" 
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Trung bình/đơn" Style="{StaticResource CaptionStyle}"/>
                    <TextBlock Text="{Binding AveragePerInvoice, Converter={StaticResource CurrencyConverter}}" 
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentPurpleBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Lợi nhuận ước tính" Style="{StaticResource CaptionStyle}"/>
                    <TextBlock Text="{Binding EstimatedProfit, Converter={StaticResource CurrencyConverter}}" 
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Invoice List with Grouping -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Chi tiết hóa đơn bán hàng" 
                           Style="{StaticResource HeadlineStyle}" Margin="0,0,0,12"/>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding SalesInvoices}"
                          Style="{StaticResource MacDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource MacDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource MacDataGridCellStyle}"
                          RowStyle="{StaticResource MacDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã HĐ" Binding="{Binding InvoiceCode}" Width="100"/>
                        <DataGridTextColumn Header="Ngày" Binding="{Binding InvoiceDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="Nhân viên" Binding="{Binding EmployeeName}" Width="120"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}}" Width="120"/>
                        <DataGridTextColumn Header="Giảm giá" Binding="{Binding Discount, Converter={StaticResource CurrencyConverter}}" Width="100"/>
                        <DataGridTextColumn Header="Thanh toán" Binding="{Binding FinalAmount, Converter={StaticResource CurrencyConverter}}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
