<UserControl x:Class="VClothes.Views.RevenueStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters">

    <UserControl.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter Bar -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Từ ngày:" VerticalAlignment="Center" 
                           Style="{StaticResource SecondaryBodyStyle}" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding TuNgay}"
                            Style="{StaticResource MacDatePickerStyle}" Width="140"/>

                <TextBlock Grid.Column="2" Text="Đến ngày:" VerticalAlignment="Center" 
                           Style="{StaticResource SecondaryBodyStyle}" Margin="16,0,8,0"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding DenNgay}"
                            Style="{StaticResource MacDatePickerStyle}" Width="140"/>

                <Button Grid.Column="5" Content="Xem thống kê" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding LenhLoc}"/>
            </Grid>
        </Border>

        <!-- Summary Cards -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Tổng doanh thu" Style="{StaticResource CaptionStyle}"/>
                    <TextBlock Text="{Binding TongDoanhThu, Converter={StaticResource CurrencyConverter}}" 
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Số hóa đơn" Style="{StaticResource CaptionStyle}"/>
                    <TextBlock Text="{Binding TongHoaDon}" 
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Trung bình/đơn" Style="{StaticResource CaptionStyle}"/>
                    <TextBlock Text="{Binding TrungBinhMoiDon, Converter={StaticResource CurrencyConverter}}" 
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentPurpleBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Lợi nhuận ước tính" Style="{StaticResource CaptionStyle}"/>
                    <TextBlock Text="{Binding LoiNhuanUocTinh, Converter={StaticResource CurrencyConverter}}" 
                               FontFamily="{StaticResource SFProFont}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Invoice List with Grouping -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Chi tiết hóa đơn bán hàng" 
                           Style="{StaticResource HeadlineStyle}" Margin="0,0,0,12"/>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding DanhSachHoaDonBan}"
                          Style="{StaticResource MacDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource MacDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource MacDataGridCellStyle}"
                          RowStyle="{StaticResource MacDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã HĐ" Binding="{Binding MaHoaDon}" Width="100"/>
                        <DataGridTextColumn Header="Ngày" Binding="{Binding NgayBan, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                        <DataGridTextColumn Header="Nhân viên" Binding="{Binding TenNhanVien}" Width="120"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, Converter={StaticResource CurrencyConverter}}" Width="120"/>
                        <DataGridTextColumn Header="Giảm giá" Binding="{Binding GiamGia, Converter={StaticResource CurrencyConverter}}" Width="100"/>
                        <DataGridTextColumn Header="Thanh toán" Binding="{Binding ThanhToan, Converter={StaticResource CurrencyConverter}}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
