<UserControl x:Class="VClothes.Views.PurchaseInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Invoice List -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Danh sách phiếu nhập" Style="{StaticResource HeadlineStyle}"/>
                        <Button Content="+ Tạo phiếu nhập" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CreateCommand}"
                                HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding FilterFromDate}"
                                    Style="{StaticResource MacDatePickerStyle}"
                                    Width="130" Margin="8,0,0,0"/>
                        <DatePicker Grid.Column="2" SelectedDate="{Binding FilterToDate}"
                                    Style="{StaticResource MacDatePickerStyle}"
                                    Width="130" Margin="8,0,0,0"/>
                    </Grid>

                    <DataGrid Grid.Row="2" 
                              ItemsSource="{Binding Invoices}"
                              SelectedItem="{Binding SelectedInvoice}"
                              Style="{StaticResource MacDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource MacDataGridColumnHeaderStyle}"
                              CellStyle="{StaticResource MacDataGridCellStyle}"
                              RowStyle="{StaticResource MacDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã phiếu" Binding="{Binding InvoiceCode}" Width="100"/>
                            <DataGridTextColumn Header="Ngày nhập" Binding="{Binding InvoiceDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Nhà cung cấp" Binding="{Binding Supplier.Name}" Width="*"/>
                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right: Invoice Form / Detail -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                    Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Tạo phiếu nhập hàng" 
                                   Style="{StaticResource HeadlineStyle}" Margin="0,0,0,16"/>

                        <TextBlock Text="MÃ PHIẾU" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditInvoiceCode, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MacTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="NGÀY NHẬP" Style="{StaticResource FormLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding EditInvoiceDate}"
                                    Style="{StaticResource MacDatePickerStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="NHÀ CUNG CẤP" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding EditSupplier}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MacComboBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="GHI CHÚ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditNote, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MacTextBoxStyle}" 
                                 Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Margin="0,0,0,16"/>

                        <!-- Add Detail Item -->
                        <Border Background="{StaticResource HoverBackgroundBrush}" 
                                CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="THÊM SẢN PHẨM" Style="{StaticResource FormLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Products}"
                                          SelectedItem="{Binding SelectedProduct}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource MacComboBoxStyle}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding EditQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource MacTextBoxStyle}"
                                             Tag="Số lượng"/>
                                    <TextBox Grid.Column="2" 
                                             Text="{Binding EditUnitPrice, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource MacTextBoxStyle}"
                                             Tag="Đơn giá"/>
                                    <Button Grid.Column="4" Content="Thêm" 
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding AddDetailCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Detail Items List -->
                        <DataGrid ItemsSource="{Binding InvoiceDetails}"
                                  Style="{StaticResource MacDataGridStyle}"
                                  RowHeight="36" MaxHeight="200"
                                  ColumnHeaderStyle="{StaticResource MacDataGridColumnHeaderStyle}"
                                  CellStyle="{StaticResource MacDataGridCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="50"/>
                                <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, Converter={StaticResource CurrencyConverter}}" Width="100"/>
                                <DataGridTextColumn Header="Thành tiền" Binding="{Binding Total, Converter={StaticResource CurrencyConverter}}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Total -->
                        <Border Background="{StaticResource HoverBackgroundBrush}" 
                                CornerRadius="8" Padding="12" Margin="0,12,0,16">
                            <Grid>
                                <TextBlock Text="TỔNG CỘNG" Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}}" 
                                           FontFamily="{StaticResource SFProFont}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Validation -->
                        <TextBlock Text="{Binding ValidationMessage}" 
                                   FontFamily="{StaticResource SFProFont}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ValidationMessage, Converter={StaticResource StringNotEmpty}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Hủy" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                            <Button Content="Lưu phiếu nhập" Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding SaveCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Placeholder -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                    Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📥" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Tạo phiếu nhập mới hoặc&#x0a;chọn phiếu để xem chi tiết" 
                               Style="{StaticResource SecondaryBodyStyle}" 
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
