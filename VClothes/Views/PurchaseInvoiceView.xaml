<UserControl x:Class="VClothes.Views.PurchaseInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters"
             xmlns:views="clr-namespace:VClothes.Views">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Danh sách phiếu nhập hàng" Style="{StaticResource HeadlineStyle}"/>
                <Button Content="+ Tạo phiếu nhập" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CreateCommand}" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Search & Filter -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding FilterFromDate}"
                            Style="{StaticResource MacDatePickerStyle}" Width="130" Margin="8,0,0,0"/>
                <DatePicker Grid.Column="2" SelectedDate="{Binding FilterToDate}"
                            Style="{StaticResource MacDatePickerStyle}" Width="130" Margin="8,0,0,0"/>
            </Grid>

            <!-- Skeleton -->
            <views:SkeletonLoading Grid.Row="2"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Invoice List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                <ItemsControl ItemsSource="{Binding Invoices}"
                              converters:StaggerAnimationBehavior.IsEnabled="True">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,4" CornerRadius="8" Background="White"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Cursor="Hand">
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding InvoiceCode}" FontWeight="Medium"
                                               FontFamily="{StaticResource SFProFont}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding InvoiceDate, StringFormat=dd/MM/yyyy}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontFamily="{StaticResource SFProFont}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Supplier.Name}"
                                               FontFamily="{StaticResource SFProFont}" FontSize="13" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}}"
                                               FontFamily="{StaticResource SFProFont}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Slide-up Create Panel -->
            <Border Grid.Row="2" VerticalAlignment="Bottom"
                    Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibility}}"
                    Background="White" CornerRadius="12" Padding="20" Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
                <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCreating}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Tạo phiếu nhập hàng" Style="{StaticResource HeadlineStyle}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="MÃ PHIẾU" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditInvoiceCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NGÀY NHẬP" Style="{StaticResource FormLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding EditInvoiceDate}" Style="{StaticResource MacDatePickerStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="NHÀ CUNG CẤP" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding EditSupplier}"
                                      DisplayMemberPath="Name" Style="{StaticResource MacComboBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="GHI CHÚ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                    </StackPanel>

                    <!-- Add product to invoice -->
                    <Border Background="{StaticResource HoverBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="80"/><ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="100"/><ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                                      DisplayMemberPath="Name" Style="{StaticResource MacComboBoxStyle}"/>
                            <TextBox Grid.Column="2" Text="{Binding EditQuantity, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MacTextBoxStyle}"/>
                            <TextBox Grid.Column="4" Text="{Binding EditUnitPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MacTextBoxStyle}"/>
                            <Button Grid.Column="6" Content="Thêm" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddDetailCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Detail items -->
                    <ItemsControl ItemsSource="{Binding InvoiceDetails}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,2" CornerRadius="4" Background="#F9FAFB" Padding="10,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ProductName}" FontFamily="{StaticResource SFProFont}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontFamily="{StaticResource SFProFont}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding UnitPrice, Converter={StaticResource CurrencyConverter}}" FontFamily="{StaticResource SFProFont}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Total, Converter={StaticResource CurrencyConverter}}" FontFamily="{StaticResource SFProFont}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Total -->
                    <Border Background="{StaticResource HoverBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <TextBlock Text="TỔNG CỘNG" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}}"
                                       FontFamily="{StaticResource SFProFont}" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Validation -->
                    <TextBlock Text="{Binding ValidationMessage}" FontFamily="{StaticResource SFProFont}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValidationMessage, Converter={StaticResource StringNotEmpty}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Hủy" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                        <Button Content="Lưu phiếu nhập" Style="{StaticResource SuccessButtonStyle}" Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
