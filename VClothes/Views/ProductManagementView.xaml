<UserControl x:Class="VClothes.Views.ProductManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Product List -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Danh sách sản phẩm" Style="{StaticResource HeadlineStyle}"/>
                    <Button Content="+ Thêm sản phẩm" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>

                <!-- Search & Filter -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"/>
                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedFilterCategory}"
                              DisplayMemberPath="Name"
                              Style="{StaticResource MacComboBoxStyle}"
                              Width="150" Margin="8,0,0,0"/>
                </Grid>

                <DataGrid Grid.Row="2" 
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          Style="{StaticResource MacDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource MacDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource MacDataGridCellStyle}"
                          RowStyle="{StaticResource MacDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã SP" Binding="{Binding ProductCode}" Width="80"/>
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="60"/>
                        <DataGridTextColumn Header="Màu" Binding="{Binding Color}" Width="70"/>
                        <DataGridTextColumn Header="Giá bán" Binding="{Binding Price, Converter={StaticResource CurrencyConverter}}" Width="110"/>
                        <DataGridTextColumn Header="Tồn kho" Binding="{Binding StockQuantity}" Width="70"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFF0EB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="#EBFFF0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Ẩn"/>
                                                    <Setter Property="Foreground" Value="#FF3B30"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Text" Value="Đang bán"/>
                                                            <Setter Property="Foreground" Value="#34C759"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Right: Edit Form -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Thông tin sản phẩm" 
                               Style="{StaticResource HeadlineStyle}" Margin="0,0,0,16"/>

                    <!-- Image Preview -->
                    <Border Width="120" Height="120" CornerRadius="12" 
                            Background="{StaticResource HoverBackgroundBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,12"
                            Cursor="Hand">
                        <Grid>
                            <Image Source="{Binding EditImagePath, Converter={StaticResource ImagePathConverter}}"
                                   Stretch="UniformToFill"/>
                            <TextBlock Text="📷&#x0a;Chọn ảnh" 
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"/>
                        </Grid>
                    </Border>
                    <Button Content="Chọn hình ảnh" 
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseImageCommand}"
                            HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Form Fields -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MÃ SẢN PHẨM" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditProductCode, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="TÊN SẢN PHẨM" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="LOẠI SẢN PHẨM" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding AllCategories}"
                                  SelectedItem="{Binding EditCategory}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MacComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="NHÀ CUNG CẤP" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding AllSuppliers}"
                                  SelectedItem="{Binding EditSupplier}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MacComboBoxStyle}"/>
                    </StackPanel>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GIÁ BÁN" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditPrice, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="GIÁ NHẬP" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditCostPrice, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SIZE" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditSize, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="MÀU SẮC" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditColor, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="CHẤT LIỆU" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditMaterial, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="MÔ TẢ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MacTextBoxStyle}" 
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <CheckBox Content="Đang kinh doanh" 
                              IsChecked="{Binding EditIsActive}"
                              FontFamily="{StaticResource SFProFont}" FontSize="13"
                              Margin="0,12,0,16"/>

                    <!-- Validation -->
                    <TextBlock Text="{Binding ValidationMessage}" 
                               FontFamily="{StaticResource SFProFont}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValidationMessage, Converter={StaticResource StringNotEmpty}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ValidationMessage}" Value="Lưu thành công!">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                        <Button Content="Xóa" Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding DeleteCommand}" Margin="0,0,8,0"/>
                        <Button Content="Lưu" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="👕" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Chọn hoặc thêm sản phẩm" 
                           Style="{StaticResource SecondaryBodyStyle}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
