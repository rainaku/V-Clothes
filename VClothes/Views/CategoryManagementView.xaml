<UserControl x:Class="VClothes.Views.CategoryManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>

        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-10" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Danh sách loại sản phẩm" Style="{StaticResource HeadlineStyle}"/>
                <Button Content="+ Thêm mới" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddCommand}"
                        HorizontalAlignment="Right"/>
            </Grid>

            <!-- Search -->
            <TextBox Grid.Row="1" 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchTextBoxStyle}"
                     Margin="0,0,0,12"/>

            <!-- Skeleton Loading -->
            <views:SkeletonLoading Grid.Row="2"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                                   xmlns:views="clr-namespace:VClothes.Views"/>

            <!-- List with inline expand -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemRoot" Margin="0,0,0,4" CornerRadius="8" 
                                    Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonDown="Item_Click">
                                <Border.RenderTransform>
                                    <TranslateTransform/>
                                </Border.RenderTransform>
                                <StackPanel>
                                    <!-- Row summary -->
                                    <Grid Margin="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Id}" 
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   FontFamily="{StaticResource SFProFont}" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                                   FontFamily="{StaticResource SFProFont}" FontSize="13"
                                                   FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Description}" 
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   FontFamily="{StaticResource SFProFont}" FontSize="13"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="3" CornerRadius="10" Padding="8,3" 
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FFF0EB"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#EBFFF0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="Medium"
                                                       FontFamily="{StaticResource SFProFont}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Ẩn"/>
                                                        <Setter Property="Foreground" Value="#FF3B30"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Text" Value="Hoạt động"/>
                                                                <Setter Property="Foreground" Value="#34C759"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>

                                    <!-- Expanded edit form (shown when this item is selected) -->
                                    <Border x:Name="EditPanel" 
                                            Background="#F9FAFB" CornerRadius="0,0,8,8"
                                            Padding="16,12" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Visibility="Collapsed">
                                        <Border.RenderTransform>
                                            <TranslateTransform/>
                                        </Border.RenderTransform>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="EditPanel" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Inline Edit Form (below the list, expands when editing) -->
            <Border Grid.Row="2" VerticalAlignment="Bottom"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                    Background="White" CornerRadius="12" Padding="20"
                    Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Chỉnh sửa loại sản phẩm" 
                               Style="{StaticResource HeadlineStyle}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="TÊN LOẠI SẢN PHẨM" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="MÔ TẢ" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="Đang hoạt động" 
                              IsChecked="{Binding EditIsActive}"
                              FontFamily="{StaticResource SFProFont}" FontSize="13"
                              Margin="0,12,0,0"/>

                    <!-- Validation -->
                    <TextBlock Text="{Binding ValidationMessage}" 
                               FontFamily="{StaticResource SFProFont}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValidationMessage, Converter={StaticResource StringNotEmpty}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ValidationMessage}" Value="Lưu thành công!">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Hủy" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                        <Button Content="Xóa" Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding DeleteCommand}" Margin="0,0,8,0"/>
                        <Button Content="Lưu" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
