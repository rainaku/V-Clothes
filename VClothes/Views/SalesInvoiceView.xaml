<UserControl x:Class="VClothes.Views.SalesInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VClothes.Converters"
             xmlns:views="clr-namespace:VClothes.Views">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Danh sách hóa đơn bán hàng" Style="{StaticResource HeadlineStyle}"/>
                <Button Content="+ Tạo hóa đơn" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding LenhTao}" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Search & Filter -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding TimKiem, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding LocTuNgay}"
                            Style="{StaticResource MacDatePickerStyle}" Width="130" Margin="8,0,0,0"/>
                <DatePicker Grid.Column="2" SelectedDate="{Binding LocDenNgay}"
                            Style="{StaticResource MacDatePickerStyle}" Width="130" Margin="8,0,0,0"/>
            </Grid>

            <!-- Skeleton -->
            <views:SkeletonLoading Grid.Row="2"
                                   Visibility="{Binding DangTai, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Invoice List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding DangTai, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                <ItemsControl ItemsSource="{Binding DanhSachHoaDon}"
                              converters:StaggerAnimationBehavior.IsEnabled="True">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,4" CornerRadius="8" Background="White"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonDown="MucDuocChon_Click">
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding MaHoaDon}" FontWeight="Medium"
                                               FontFamily="{StaticResource SFProFont}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding NgayBan, StringFormat=dd/MM/yyyy}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontFamily="{StaticResource SFProFont}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding KhachHang.HoTen, FallbackValue='Khách lẻ'}"
                                               FontFamily="{StaticResource SFProFont}" FontSize="13" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ThanhToan, Converter={StaticResource CurrencyConverter}}"
                                               FontFamily="{StaticResource SFProFont}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Detail View Panel -->
            <Border Grid.Row="2" VerticalAlignment="Bottom"
                    Visibility="{Binding DangXemChiTiet, Converter={StaticResource BoolToVisibility}}"
                    Background="White" CornerRadius="12" Padding="20" Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentGreenBrush}" BorderThickness="1">
                <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DangXemChiTiet}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.1" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Chi tiết hóa đơn: " Style="{StaticResource HeadlineStyle}"/>
                            <TextBlock Text="{Binding HoaDonDuocChon.MaHoaDon}" Style="{StaticResource HeadlineStyle}"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </StackPanel>
                        <Button Content="✕" Style="{StaticResource IconButtonStyle}" HorizontalAlignment="Right"
                                Command="{Binding LenhDongChiTiet}" Width="28" Height="28"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ChiTietHoaDonDuocChon}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,3" CornerRadius="6" Background="#F9FAFB" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TenSanPham}" FontFamily="{StaticResource SFProFont}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SoLuong, StringFormat='x{0}'}" FontFamily="{StaticResource SFProFont}" FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DonGia, Converter={StaticResource CurrencyConverter}}" FontFamily="{StaticResource SFProFont}" FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ThanhTien, Converter={StaticResource CurrencyConverter}}" FontFamily="{StaticResource SFProFont}" FontSize="13"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="{StaticResource HoverBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Tổng tiền hàng:" Style="{StaticResource SecondaryBodyStyle}"/>
                                <TextBlock Text="{Binding HoaDonDuocChon.TongTien, Converter={StaticResource CurrencyConverter}}"
                                           HorizontalAlignment="Right" FontFamily="{StaticResource SFProFont}"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Giảm giá:" Style="{StaticResource SecondaryBodyStyle}"/>
                                <TextBlock Text="{Binding HoaDonDuocChon.GiamGia, Converter={StaticResource CurrencyConverter}}"
                                           HorizontalAlignment="Right" FontFamily="{StaticResource SFProFont}" Foreground="{StaticResource AccentRedBrush}"/>
                            </Grid>
                            <Separator Style="{StaticResource SeparatorStyle}"/>
                            <Grid>
                                <TextBlock Text="THANH TOÁN" FontFamily="{StaticResource SFProFont}" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding HoaDonDuocChon.ThanhToan, Converter={StaticResource CurrencyConverter}}"
                                           FontFamily="{StaticResource SFProFont}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Slide-up Create Panel -->
            <Border Grid.Row="2" VerticalAlignment="Bottom"
                    Visibility="{Binding DangTao, Converter={StaticResource BoolToVisibility}}"
                    Background="White" CornerRadius="12" Padding="20" Margin="0,8,0,0"
                    BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
                <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DangTao}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Tạo hóa đơn bán hàng" Style="{StaticResource HeadlineStyle}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="MÃ HÓA ĐƠN" Style="{StaticResource FormLabelStyle}"/>
                            <TextBox Text="{Binding SuaMaHoaDon, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NGÀY BÁN" Style="{StaticResource FormLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding SuaNgayBan}" Style="{StaticResource MacDatePickerStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="KHÁCH HÀNG" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding DanhSachKhachHang}" SelectedItem="{Binding SuaKhachHang}"
                                      DisplayMemberPath="HoTen" Style="{StaticResource MacComboBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="GHI CHÚ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding SuaGhiChu, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MacTextBoxStyle}"/>
                    </StackPanel>

                    <!-- Add product -->
                    <Border Background="{StaticResource HoverBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="80"/><ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="100"/><ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding DanhSachSanPham}" SelectedItem="{Binding SanPhamDuocChon}"
                                      DisplayMemberPath="Ten" Style="{StaticResource MacComboBoxStyle}"/>
                            <TextBox Grid.Column="2" Text="{Binding SuaSoLuong, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MacTextBoxStyle}"/>
                            <TextBox Grid.Column="4" Text="{Binding SuaDonGia, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MacTextBoxStyle}"/>
                            <Button Grid.Column="6" Content="Thêm" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding LenhThemChiTiet}"/>
                        </Grid>
                    </Border>

                    <!-- Detail items -->
                    <ItemsControl ItemsSource="{Binding DanhSachChiTiet}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,2" CornerRadius="4" Background="#F9FAFB" Padding="10,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="105"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TenSanPham}" FontFamily="{StaticResource SFProFont}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SoLuong}" FontFamily="{StaticResource SFProFont}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DonGia, Converter={StaticResource CurrencyConverter}}" FontFamily="{StaticResource SFProFont}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ThanhTien, Converter={StaticResource CurrencyConverter}}" FontFamily="{StaticResource SFProFont}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Totals -->
                    <Border Background="{StaticResource HoverBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Tổng tiền hàng:" Style="{StaticResource SecondaryBodyStyle}"/>
                                <TextBlock Text="{Binding TongTien, Converter={StaticResource CurrencyConverter}}"
                                           HorizontalAlignment="Right" FontFamily="{StaticResource SFProFont}" FontWeight="Medium"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Giảm giá:" Style="{StaticResource SecondaryBodyStyle}" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding SuaGiamGia, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MacTextBoxStyle}" Width="120" Height="28" FontSize="12"
                                         HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Style="{StaticResource SeparatorStyle}"/>
                            <Grid>
                                <TextBlock Text="THANH TOÁN:" FontFamily="{StaticResource SFProFont}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ThanhToan, Converter={StaticResource CurrencyConverter}}"
                                           FontFamily="{StaticResource SFProFont}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Validation -->
                    <TextBlock Text="{Binding ThongBaoXacThuc}" FontFamily="{StaticResource SFProFont}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ThongBaoXacThuc, Converter={StaticResource StringNotEmpty}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Hủy" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding LenhHuy}" Margin="0,0,8,0"/>
                        <Button Content="Lưu hóa đơn" Style="{StaticResource SuccessButtonStyle}" Command="{Binding LenhLuu}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
