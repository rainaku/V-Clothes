<Window x:Class="VClothes.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VClothes.ViewModels"
        xmlns:views="clr-namespace:VClothes.Views"
        xmlns:converters="clr-namespace:VClothes.Converters"
        Title="V-Clothes" 
        Height="768" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- View DataTemplates -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoryManagementViewModel}">
            <views:CategoryManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierManagementViewModel}">
            <views:SupplierManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductManagementViewModel}">
            <views:ProductManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeeManagementViewModel}">
            <views:EmployeeManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PurchaseInvoiceViewModel}">
            <views:PurchaseInvoiceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesInvoiceViewModel}">
            <views:SalesInvoiceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RevenueStatisticsViewModel}">
            <views:RevenueStatisticsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView/>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="12" Background="{StaticResource WindowBackgroundBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12"
                    Background="{StaticResource SidebarBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sidebar Header with window controls -->
                    <StackPanel Grid.Row="0" Margin="16,16,16,20">
                        <!-- Windows Window Controls -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Click="MinimizeButton_Click" Cursor="Hand" Width="36" Height="28" Margin="0,0,2,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{StaticResource SidebarTextBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#3A3A3C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Click="MaximizeButton_Click" Cursor="Hand" Width="36" Height="28" Margin="0,0,2,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                            <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{StaticResource SidebarTextBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#3A3A3C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Click="CloseButton_Click" Cursor="Hand" Width="36" Height="28">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                            <TextBlock x:Name="icon" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{StaticResource SidebarTextBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- App Logo -->
                        <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                            <Border Width="32" Height="32" CornerRadius="8" 
                                    Background="#3A3A3C" Margin="0,0,10,0">
                                <TextBlock Text="👕" FontSize="16" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="V-Clothes" 
                                           FontFamily="{StaticResource SFProFont}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="Quản lý cửa hàng" 
                                           FontFamily="{StaticResource SFProFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SidebarSecondaryTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Navigation Menu -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- Main Section -->
                            <TextBlock Text="TỔNG QUAN" 
                                       FontFamily="{StaticResource SFProFont}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource SidebarSecondaryTextBrush}"
                                       Margin="20,8,0,4"/>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}" 
                                         IsChecked="True"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="Dashboard">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tổng quan" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- Catalog Section -->
                            <TextBlock Text="DANH MỤC" 
                                       FontFamily="{StaticResource SFProFont}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource SidebarSecondaryTextBrush}"
                                       Margin="20,20,0,4"/>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="Categories">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏷️" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Loại sản phẩm" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="Suppliers">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏭" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhà cung cấp" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="Products">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👕" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sản phẩm" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="Employees"
                                         Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhân viên" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- Invoices Section -->
                            <TextBlock Text="GIAO DỊCH" 
                                       FontFamily="{StaticResource SFProFont}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource SidebarSecondaryTextBrush}"
                                       Margin="20,20,0,4"/>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="PurchaseInvoices">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Phiếu nhập hàng" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="SalesInvoices">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧾" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Hóa đơn bán hàng" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- Reports Section -->
                            <TextBlock Text="BÁO CÁO" 
                                       FontFamily="{StaticResource SFProFont}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource SidebarSecondaryTextBrush}"
                                       Margin="20,20,0,4"/>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="Revenue">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💰" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Thống kê doanh thu" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Command="{Binding NavigateCommand}" 
                                         CommandParameter="Reports">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Báo cáo" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- User Info & Logout -->
                    <Border Grid.Row="2" BorderBrush="#3A3A3C" BorderThickness="0,1,0,0"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="36" Height="36" CornerRadius="18" 
                                    Background="#3A3A3C">
                                <TextBlock Text="👤" FontSize="16" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="{Binding UserDisplayName}" 
                                           FontFamily="{StaticResource SFProFont}"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding UserRole}" 
                                           FontFamily="{StaticResource SFProFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource SidebarSecondaryTextBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="2" 
                                    Command="{Binding LogoutCommand}"
                                    ToolTip="Đăng xuất"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="Transparent" 
                                                CornerRadius="6" Padding="6">
                                            <TextBlock Text="⏻" FontSize="14" 
                                                       Foreground="{StaticResource SidebarSecondaryTextBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3A3A3C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0" Padding="24,16" Background="Transparent"
                        MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="{Binding CurrentViewTitle}" 
                                   Style="{StaticResource Title2Style}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Content with fade animation -->
                <ContentControl Grid.Row="1" 
                                Content="{Binding CurrentViewModel}"
                                Margin="24,0,24,24">
                    <ContentControl.RenderTransform>
                        <TranslateTransform/>
                    </ContentControl.RenderTransform>
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <Trigger Property="Content" Value="{x:Null}">
                                    <Setter Property="Opacity" Value="0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                    <ContentControl.Triggers>
                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ContentControl.Triggers>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>
