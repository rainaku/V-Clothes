<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- macOS-inspired Color Palette -->
    <!-- Background Colors -->
    <Color x:Key="WindowBackgroundColor">#F5F5F7</Color>
    <Color x:Key="SidebarBackgroundColor">#1D1D1F</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ContentBackgroundColor">#F5F5F7</Color>
    <Color x:Key="HoverBackgroundColor">#E8E8ED</Color>
    <Color x:Key="SelectedBackgroundColor">#007AFF</Color>
    <Color x:Key="SidebarHoverColor">#2C2C2E</Color>
    <Color x:Key="SidebarSelectedColor">#3A3A3C</Color>

    <!-- Text Colors -->
    <Color x:Key="PrimaryTextColor">#1D1D1F</Color>
    <Color x:Key="SecondaryTextColor">#6E6E73</Color>
    <Color x:Key="TertiaryTextColor">#AEAEB2</Color>
    <Color x:Key="WhiteTextColor">#FFFFFF</Color>
    <Color x:Key="SidebarTextColor">#E5E5EA</Color>
    <Color x:Key="SidebarSecondaryTextColor">#8E8E93</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentBlueColor">#007AFF</Color>
    <Color x:Key="AccentGreenColor">#34C759</Color>
    <Color x:Key="AccentRedColor">#FF3B30</Color>
    <Color x:Key="AccentOrangeColor">#FF9500</Color>
    <Color x:Key="AccentPurpleColor">#AF52DE</Color>
    <Color x:Key="AccentTealColor">#5AC8FA</Color>
    <Color x:Key="AccentYellowColor">#FFCC00</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#E5E5EA</Color>
    <Color x:Key="FocusBorderColor">#007AFF</Color>
    <Color x:Key="DividerColor">#D1D1D6</Color>

    <!-- SolidColorBrushes -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ContentBackgroundColor}"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}"/>
    <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="{StaticResource SelectedBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{StaticResource SidebarSelectedColor}"/>

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="{StaticResource TertiaryTextColor}"/>
    <SolidColorBrush x:Key="WhiteTextBrush" Color="{StaticResource WhiteTextColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarSecondaryTextBrush" Color="{StaticResource SidebarSecondaryTextColor}"/>

    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRedColor}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurpleColor}"/>
    <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource AccentTealColor}"/>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource AccentYellowColor}"/>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1D1D1F" Offset="0"/>
        <GradientStop Color="#2C2C2E" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#007AFF" Offset="0"/>
        <GradientStop Color="#5856D6" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
